<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0,maximum-scale=5.0,user-scalable=yes">
<meta name="description" content="철학을 코드로 — OrbitPrompt 사고 시스템">
<meta name="theme-color" content="#0A1A0F">
<title>OrbitPrompt — 칠판 위에 쓰는 철학</title>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{--bg:#0A1A0F;--gold:#EEC864;--gold2:rgba(238,200,100,.35);--ink1:#FFF;--ink2:rgba(255,255,255,.5);--ink3:rgba(255,255,255,.2);--purple:#a855f7;--cyan:#22d3ee;--green:#4ade80}
html,body{background:var(--bg);color:var(--ink1);font-family:system-ui,sans-serif;height:100%;overflow:hidden}
body::before{content:'';position:fixed;inset:0;background:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='3'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");pointer-events:none;z-index:0}
body::after{content:'';position:fixed;inset:0;background:radial-gradient(ellipse 55% 45% at 25% 30%,rgba(238,200,100,.04) 0%,transparent 60%),radial-gradient(ellipse 40% 35% at 75% 70%,rgba(34,211,238,.03) 0%,transparent 50%);pointer-events:none;z-index:0}
header{position:fixed;top:0;left:0;right:0;z-index:100;padding:20px 24px;display:flex;align-items:center;justify-content:space-between;pointer-events:none;background:linear-gradient(180deg,rgba(10,26,15,.6) 0%,transparent 100%)}
header .brand{pointer-events:auto;font-family:monospace;font-size:10px;letter-spacing:.22em;color:var(--gold2);text-decoration:none}
header nav{pointer-events:auto;display:flex;gap:20px}
header nav a{font-family:monospace;font-size:9px;letter-spacing:.14em;color:var(--ink3);text-decoration:none;transition:color .3s}
header nav a:hover{color:var(--ink2)}
.title{position:fixed;z-index:50;pointer-events:none;left:50%;top:38.2%;transform:translate(-50%,-50%);text-align:center}
.title-kicker{font-family:monospace;font-size:7px;letter-spacing:.35em;color:var(--gold2);margin-bottom:12px}
.title h1{font-family:serif;font-size:clamp(24px,5vw,48px);font-weight:400;line-height:1.15;color:#fff}
.title h1 em{font-style:italic;color:var(--gold)}
.title-sub{font-size:clamp(10px,1.4vw,13px);color:var(--ink2);margin-top:8px}
#graphWrap{position:fixed;top:0;left:0;width:100vw;height:100vh;z-index:1;touch-action:none}
#graphSvg{width:100%;height:100%;display:block;cursor:grab;background:transparent}
#graphSvg:active{cursor:grabbing}
.edge{fill:none;stroke-linecap:round}
.node-label{font-family:monospace;fill:rgba(255,255,255,.3);pointer-events:none;text-anchor:middle;dominant-baseline:middle}
.node-group{cursor:pointer}
.center-label{font-family:serif;fill:var(--gold);font-style:italic;text-anchor:middle;pointer-events:none}
.hub-label{font-family:monospace;fill:rgba(255,255,255,.12);letter-spacing:.14em;text-anchor:middle;pointer-events:none;text-transform:uppercase}
#tooltip{position:fixed;z-index:200;pointer-events:none;background:rgba(10,26,15,.95);border:1px solid rgba(255,255,255,.08);border-radius:6px;padding:8px 12px;font-size:11px;color:var(--ink2);max-width:200px;opacity:0;transition:opacity .15s;backdrop-filter:blur(8px)}
#tooltip.show{opacity:1}
#autoRotateBtn{position:fixed;bottom:80px;right:16px;z-index:99;background:none;border:1px solid var(--ink3);color:var(--ink2);font-family:monospace;font-size:8px;padding:6px 12px;border-radius:4px;cursor:pointer;opacity:.4;transition:all .3s}
#autoRotateBtn:hover{opacity:1;border-color:var(--gold);color:var(--gold)}
#zoomIndicator{position:fixed;bottom:115px;right:16px;z-index:99;font-family:monospace;font-size:8px;color:var(--ink3);opacity:0;transition:opacity .3s}
footer{position:fixed;bottom:0;left:0;right:0;z-index:100;padding:16px 20px;display:flex;justify-content:center;gap:14px;flex-wrap:wrap;pointer-events:none;background:linear-gradient(0deg,rgba(10,26,15,.6) 0%,transparent 100%)}
footer a{pointer-events:auto;font-family:monospace;font-size:7px;letter-spacing:.1em;color:var(--ink3);text-decoration:none}
footer a:hover{color:var(--gold)}
@media(max-width:700px){header nav{display:none}footer{padding:10px 12px;gap:8px}.node-label{font-size:6px}}
</style>
</head>
<body>
<header>
  <a class="brand" href="/">ORBITPROMPT</a>
  <nav>
    <a href="why.html">WHY</a>
    <a href="whitepaper.html">백서</a>
    <a href="philosophy.html">철학</a>
    <a href="humanity-finger.html">휴머니티</a>
  </nav>
</header>
<div class="title">
  <div class="title-kicker">Φ · I · C · K · P · 7AXIS</div>
  <h1>칠판 위에 쓰는 <em>철학</em></h1>
  <div class="title-sub">탐색: 노드 클릭 · 드래그 회전 · 핀치/휠 확대</div>
</div>
<button id="autoRotateBtn">◈ 자동 회전</button>
<div id="zoomIndicator">100%</div>
<div id="graphWrap"><svg id="graphSvg" viewBox="-600 -600 1200 1200"></svg></div>
<div id="tooltip"></div>
<footer>
  <a href="identity.html">정체성</a>
  <a href="humility.html">겸손</a>
  <a href="docs/JUSTIFICATION-REPORT.md">정당성</a>
  <a href="docs/AI-MISSIONARY-PLUGIN-WHITEPAPER.md">미셔너</a>
  <a href="archive.html">Archive</a>
  <a href="https://github.com/dtslib1979/OrbitPrompt">GitHub</a>
</footer>
<script>
(function(){
"use strict";
var GOLD="#EEC864", PUR="#a855f7", CYAN="#22d3ee", GRN="#4ade80", WHT="#fff";
var HUBS={
  phi:{label:"철학",x:-260,y:-160,color:GOLD,desc:"Φ7 철학 체계"},
  mod:{label:"모듈",x:290,y:-130,color:PUR,desc:"사고 모듈"},
  mcp:{label:"MCP",x:320,y:260,color:CYAN,desc:"MCP 서버 모음"},
  gen:{label:"생성기",x:-270,y:220,color:GRN,desc:"프롬프트 생성기"},
  arch:{label:"아카이브",x:-400,y:60,color:WHT,desc:"기록과 자료"}
};
var LEAVES={
  phi:[{label:"WHY",href:"why.html"},{label:"백서",href:"whitepaper.html"},{label:"7축 철학",href:"philosophy.html"},{label:"휴머니티",href:"humanity-finger.html"}],
  mod:[{label:"축구 모델",href:"football-model/index.html"},{label:"WC2026",href:"football-model/wc2026-predictor.html"},{label:"선거 MCP",href:"boards/election-gallery.html"},{label:"달러 시스템",href:"boards/dollar-system-whitepaper.html"}],
  mcp:[{label:"정치 MCP",href:"political-mcp/index.html"},{label:"금융 MCP",href:"parksy-finance-mcp/index.html"},{label:"교육 MCP",href:"edu-mcp/mcp/server.py"},{label:"Media MCP",href:"media-mcp/mcp/server.py"}],
  gen:[{label:"칠판",href:"prompts/chalkboard/index.html"},{label:"Identity",href:"prompts/identity/index.html"},{label:"Broadcast",href:"prompts/broadcast/parksy-brain-season.html"},{label:"PWA",href:"prompts/apk/index.html"}],
  arch:[{label:"Archive",href:"archive.html"},{label:"Map",href:"map.html"},{label:"Links",href:"links/index.html"},{label:"정당성",href:"docs/JUSTIFICATION-REPORT.md"},{label:"미셔너",href:"docs/AI-MISSIONARY-PLUGIN-WHITEPAPER.md"}]
};
var NS="http://www.w3.org/2000/svg";
var svg=document.getElementById("graphSvg");
var hubEls={}, leafEls=[], edgeEls=[];

function make(tag,attrs){
  var e=document.createElementNS(NS,tag);
  if(attrs) for(var k in attrs) if(attrs.hasOwnProperty(k)) e.setAttribute(k,attrs[k]);
  return e;
}

// Center
var cGlow1=make("circle",{cx:0,cy:0,r:70,fill:"none",stroke:GOLD,"stroke-width":.3,opacity:.05});
svg.appendChild(cGlow1);
var cGlow2=make("circle",{cx:0,cy:0,r:45,fill:"none",stroke:GOLD,"stroke-width":.4,opacity:.07});
svg.appendChild(cGlow2);
var cTxt=make("text",{x:0,y:0,"class":"center-label"});
cTxt.textContent="OrbitPrompt";
svg.appendChild(cTxt);

Object.keys(HUBS).forEach(function(id){
  var hub=HUBS[id], hx=hub.x, hy=hub.y;
  var leaves=LEAVES[id]||[];
  var ring=make("circle",{cx:0,cy:0,r:Math.sqrt(hx*hx+hy*hy),fill:"none",stroke:"rgba(255,255,255,.04)","stroke-width":.5});
  svg.appendChild(ring);
  var hGlow=make("circle",{cx:hx,cy:hy,r:55,fill:"none",stroke:hub.color,"stroke-width":.4,opacity:.08});
  svg.appendChild(hGlow);
  var g=make("g",{"class":"node-group","data-hub":id});
  var dot=make("circle",{cx:hx,cy:hy,r:7,fill:hub.color,opacity:.7});
  g.appendChild(dot);
  var inner=make("circle",{cx:hx,cy:hy,r:2.5,fill:WHT,opacity:.3});
  g.appendChild(inner);
  var lbl=make("text",{x:hx,y:hy+17,"class":"hub-label",fill:hub.color});
  lbl.textContent=hub.label;
  g.appendChild(lbl);
  svg.appendChild(g);
  hubEls[id]={g:g,dot:dot,glow:hGlow,ring:ring,lbl:lbl,x:hx,y:hy};
  var ce=make("line",{x1:0,y1:0,x2:hx,y2:hy,"class":"edge",stroke:hub.color,"stroke-width":.4,opacity:.04});
  svg.appendChild(ce);
  edgeEls.push(ce);
  
  leaves.forEach(function(leaf,i){
    var total=leaves.length;
    var angle=i/total*Math.PI*2-Math.PI/2+id.length*0.2;
    var dist=55+(i%2)*10;
    var lx=hx+Math.cos(angle)*dist, ly=hy+Math.sin(angle)*dist*0.6;
    var edge=make("line",{x1:hx,y1:hy,x2:lx,y2:ly,"class":"edge",stroke:"rgba(255,255,255,.06)","stroke-width":.5,opacity:.06});
    svg.appendChild(edge);
    edgeEls.push(edge);
    var a=document.createElementNS(NS,"a");
    a.setAttributeNS("http://www.w3.org/1999/xlink","href",leaf.href);
    a.setAttribute("href",leaf.href);
    a.setAttribute("class","node-group");
    a.setAttribute("data-leaf",id+"_"+i);
    var ld=make("circle",{cx:lx,cy:ly,r:2.5,fill:leaf.color||WHT,opacity:.4});
    a.appendChild(ld);
    var ll=make("text",{x:lx,y:ly+12,"class":"node-label",fill:leaf.color||WHT});
    ll.textContent=leaf.label;
    a.appendChild(ll);
    svg.appendChild(a);
    leafEls.push({el:a,dot:ld,lbl:ll,x:lx,y:ly,leaf:leaf});
  });
});

// Interaction state
var drag=false, sx=0, sy=0;
var ax=0, ay=0, vx=0, vy=0, tx=0, ty=0;
var zoom=1, tz=1;
var autoRot=false;
var tap=true, mdX=0, mdY=0, mdT=0;
var t=0, hov=null;
var pinchDist=0, pinchZoom=1;

var wrap=document.getElementById("graphWrap");
var tip=document.getElementById("tooltip");

function go(x,y){
  var el=document.elementFromPoint(x,y);
  if(!el) return;
  var cur=el;
  while(cur&&cur!==document.body&&cur!==document.documentElement){
    var dl=cur.getAttribute?cur.getAttribute("data-leaf"):null;
    if(dl!==null){ var h=cur.getAttribute("href"); if(h&&h!=="#"){ window.location.href=h; return; } }
    var dh=cur.getAttribute?cur.getAttribute("data-hub"):null;
    if(dh!==null){ var lvs=LEAVES[dh]; if(lvs&&lvs[0]){ window.location.href=lvs[0].href; return; } }
    cur=cur.parentElement||cur.parentNode;
  }
}

// Mouse
wrap.addEventListener("mousedown",function(e){
  drag=true; tap=true; sx=e.clientX; sy=e.clientY;
  mdX=e.clientX; mdY=e.clientY; mdT=Date.now();
  vx=0; vy=0;
});
window.addEventListener("mousemove",function(e){
  if(!drag) return;
  if(Math.hypot(e.clientX-mdX,e.clientY-mdY)>5) tap=false;
  var dx=e.clientY-sy, dy=e.clientX-sx;
  tx+=dx*0.004; ty+=dy*0.004;
  vx=dx*0.004; vy=dy*0.004;
  sx=e.clientX; sy=e.clientY;
});
window.addEventListener("mouseup",function(e){
  drag=false;
  if(tap&&Date.now()-mdT<300) go(e.clientX,e.clientY);
});

window.addEventListener("touchstart",function(e){
  var tch=e.touches; mdT=Date.now();
  if(tch.length===1){
    drag=true; tap=true;
    sx=tch[0].clientX; sy=tch[0].clientY;
    mdX=sx; mdY=sy; vx=0; vy=0;
  } else if(tch.length===2){
    drag=false; tap=false;
    var dx=tch[0].clientX-tch[1].clientX, dy=tch[0].clientY-tch[1].clientY;
    pinchDist=Math.sqrt(dx*dx+dy*dy);
    pinchZoom=tz;
  }
},{passive:true});
window.addEventListener("touchmove",function(e){
  var tch=e.touches;
  if(tch.length===2){
    e.preventDefault();
    var dx=tch[0].clientX-tch[1].clientX, dy=tch[0].clientY-tch[1].clientY;
    var dist=Math.sqrt(dx*dx+dy*dy);
    if(pinchDist>0) tz=Math.max(0.2,Math.min(5,pinchZoom*(dist/pinchDist)));
    var zi=document.getElementById("zoomIndicator");
    if(zi){ zi.style.opacity="1"; clearTimeout(window._zt); window._zt=setTimeout(function(){zi.style.opacity="0";},1200); }
    return;
  }
  if(!drag||tch.length!==1) return;
  var cx=tch[0].clientX, cy=tch[0].clientY;
  if(Math.hypot(cx-mdX,cy-mdY)>8) tap=false;
  var dx=cy-sy, dy=cx-sx;
  tx+=dx*0.004; ty+=dy*0.004;
  vx=dx*0.004; vy=dy*0.004;
  sx=cx; sy=cy;
},{passive:false});
window.addEventListener("touchend",function(e){
  if(e.touches.length>0) return;
  if(tap&&Date.now()-mdT<300&&e.changedTouches[0]){
    go(e.changedTouches[0].clientX,e.changedTouches[0].clientY);
  }
  drag=false;
});

// Wheel zoom
wrap.addEventListener("wheel",function(e){
  e.preventDefault();
  tz=Math.max(0.2,Math.min(5,tz-e.deltaY*0.001));
  var zi=document.getElementById("zoomIndicator");
  zi.style.opacity="1";
  clearTimeout(window._zt);
  window._zt=setTimeout(function(){zi.style.opacity="0";},1200);
},{passive:false});

// Auto rotate
document.getElementById("autoRotateBtn").addEventListener("click",function(){
  autoRot=!autoRot;
  this.style.color=autoRot?GOLD:"";
  this.style.borderColor=autoRot?GOLD:"";
});

// Hover
Object.keys(HUBS).forEach(function(id){
  var el=document.querySelector('[data-hub="'+id+'"]');
  if(!el) return;
  el.addEventListener("mouseenter",function(e){
    var h=HUBS[id];
    tip.innerHTML="<b>"+h.label+"</b><br>"+h.desc;
    tip.style.left=(e.clientX+12)+"px"; tip.style.top=(e.clientY-8)+"px";
    tip.classList.add("show"); hov=id;
  });
  el.addEventListener("mousemove",function(e){
    tip.style.left=(e.clientX+12)+"px"; tip.style.top=(e.clientY-8)+"px";
  });
  el.addEventListener("mouseleave",function(){
    tip.classList.remove("show"); hov=null;
  });
});
document.querySelectorAll("[data-leaf]").forEach(function(el){
  el.addEventListener("mouseenter",function(e){
    var lbl=(this.querySelector(".node-label")||{}).textContent||"";
    tip.innerHTML="<b>"+lbl+"</b>";
    tip.style.left=(e.clientX+12)+"px"; tip.style.top=(e.clientY-8)+"px";
    tip.classList.add("show");
  });
  el.addEventListener("mousemove",function(e){
    tip.style.left=(e.clientX+12)+"px"; tip.style.top=(e.clientY-8)+"px";
  });
  el.addEventListener("mouseleave",function(){tip.classList.remove("show");});
});

// Keyboard
window.addEventListener("keydown",function(e){
  if(e.key==="r"||e.key==="R") document.getElementById("autoRotateBtn").click();
  if(e.key==="+"||e.key==="=") tz=Math.min(5,tz*1.15);
  if(e.key==="-") tz=Math.max(0.2,tz/1.15);
  if(e.key==="0"){ tz=1; tx=0; ty=0; ax=0; ay=0; vx=0; vy=0; }
});

// Animate
function anim(){
  try {
    t+=0.02;
    if(autoRot&&!drag){ ty+=0.002; tx+=Math.sin(t*0.25)*0.0008; }
    if(!drag){ tx+=vx*0.94; ty+=vy*0.94; vx*=0.94; vy*=0.94; if(Math.abs(vx)<5e-5)vx=0; if(Math.abs(vy)<5e-5)vy=0; }
    ax+=(tx-ax)*0.06; ay+=(ty-ay)*0.06; zoom+=(tz-zoom)*0.06;
    svg.style.transform="rotateX("+ax+"rad) rotateY("+ay+"rad) scale("+zoom+")";
    var z=Math.max(0.4,Math.min(2.5,zoom));
    var hR=5+z*2, lR=1.5+z*1.2, lFS=5+z*2.5;
    
    Object.keys(hubEls).forEach(function(id){
      var h=hubEls[id]; if(!h||!h.dot) return;
      var r=hov===id?hR*1.4:hR;
      h.dot.setAttribute("r",r+"");
      h.dot.setAttribute("opacity",hov===id?"1":"0.7");
      var fl=Math.sin(t*0.6+id.length*1.3)*4;
      if(h.g) h.g.setAttribute("transform","translate(0,"+fl.toFixed(1)+")");
      if(h.lbl){ h.lbl.setAttribute("y",(h.y+17+fl)+""); h.lbl.setAttribute("font-size",lFS+""); }
    });
    
    leafEls.forEach(function(l,i){
      if(!l||!l.dot) return;
      var fl=Math.sin(t*0.5+i*0.9)*3;
      l.dot.setAttribute("r",lR+"");
      l.dot.setAttribute("opacity",Math.min(0.6,0.2+z*0.15)+"");
      if(l.lbl){ l.lbl.setAttribute("font-size",lFS+""); l.lbl.setAttribute("y",(l.y+12+fl)+""); }
      if(l.el) l.el.setAttribute("transform","translate(0,"+fl.toFixed(1)+")");
    });
    
    if(cTxt) cTxt.setAttribute("font-size",(10+z*4)+"");
    edgeEls.forEach(function(e){if(e){e.setAttribute("stroke-width",(0.3+z*0.25).toFixed(2));e.setAttribute("opacity",Math.min(0.08,0.02+z*0.03)+"");}});
    var br=1+Math.sin(t*0.7)*0.04;
    if(cGlow1){cGlow1.setAttribute("r",(70*br*z*0.3)+"");cGlow1.setAttribute("opacity",(0.04+Math.sin(t*0.7)*0.02)+"");}
    if(cGlow2){cGlow2.setAttribute("r",(45*br*z*0.35)+"");cGlow2.setAttribute("opacity",(0.06+Math.sin(t*0.7)*0.03)+"");}
    var zi=document.getElementById("zoomIndicator");
    if(zi) zi.textContent=Math.round(zoom*100)+"%";
  } catch(e){}
  requestAnimationFrame(anim);
}
anim();

// Entry animation
setTimeout(function(){
  var nodes=document.querySelectorAll(".node-group");
  nodes.forEach(function(n,i){
    n.style.opacity="0"; n.style.transform="translateY(10px)";
    setTimeout(function(){
      n.style.transition="opacity .4s ease, transform .4s ease";
      n.style.opacity="1"; n.style.transform="translateY(0)";
    },1000+i*50);
  });
  setTimeout(function(){
    nodes.forEach(function(n){n.style.transition="";n.style.transform="";});
  },1000+nodes.length*50+400);
},200);

console.log("OrbitPrompt ready");
})();
</script>
</body>
</html>